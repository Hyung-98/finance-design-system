{
  "name": "finance-design-system",
  "version": "0.1.0",
  "description": "Finance Design System — accessible, responsive React components with TypeScript support",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.mjs",
      "require": "./dist/utils.js"
    },
    "./styles": "./styles/globals.css"
  },
  "files": [
    "dist",
    "styles/globals.css",
    "README.md"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:lib": "tsup",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "14.2.29",
    "next-themes": "^0.3.0",
    "react": "^18",
    "react-dom": "^18",
    "shiki": "^1.6.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
